<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <link rel="icon" type="image/png" href="pro9 logo.png">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>PRO9 | COMMAND</title>
    
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    
    <style>
        :root {
            --tactical-blue: #00d4ff;
            --defense-green: #00ff66;
            --training-gold: #ffcc00;
            --bg-black: #000a12;
            --siren-red: #ff0033;
            --siren-blue: #0055ff;
            --glass: rgba(0, 20, 40, 0.85);
            --border: rgba(0, 212, 255, 0.2);
        }

        body, html { 
            margin: 0; padding: 0; height: 100%; width: 100%; 
            overflow: hidden; background-color: var(--bg-black); 
            font-family: 'Consolas', 'Courier New', monospace;
        }

        /* TACTICAL HEX BACKGROUND */
        #bg-container {
            position: absolute; width: 100%; height: 100%;
            background: radial-gradient(circle at center, transparent 0%, var(--bg-black) 100%),
                        url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="60" height="52" viewBox="0 0 60 52"><path d="M30 0L60 17V45L30 52L0 45V17L30 0Z" fill="none" stroke="%2300d4ff" stroke-width="0.5" opacity="0.1"/></svg>');
            z-index: 0;
        }

        #map {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            z-index: 1;
            filter: brightness(0.3) contrast(1.2) saturate(0.2) hue-rotate(180deg);
            transition: transform 3s cubic-bezier(0.4, 0, 0.2, 1), filter 1s ease;
        }

        /* LOGO BRANDING */
        .pnp-logo-main {
            width: 100px;
            height: auto;
            filter: drop-shadow(0 0 10px var(--tactical-blue));
            opacity: 0.9;
            margin-bottom: 20px;
            animation: logo-pulse 4s ease-in-out infinite;
        }

        @keyframes logo-pulse {
            0%, 100% { filter: drop-shadow(0 0 5px var(--tactical-blue)); opacity: 0.7; transform: scale(1); }
            50% { filter: drop-shadow(0 0 20px var(--tactical-blue)); opacity: 1; transform: scale(1.05); }
        }

        .header-branding {
            position: fixed;
            top: 40px;
            width: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            z-index: 25;
            pointer-events: none;
            transition: opacity 1s ease;
        }

        /* ACTIVE CROSSHAIR */
        #crosshair {
            position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%);
            width: 200px; height: 200px; border: 1px solid rgba(0, 212, 255, 0.1);
            border-radius: 50%; z-index: 15; pointer-events: none; transition: 1s;
        }
        #crosshair::before { content: ''; position: absolute; width: 100%; height: 1px; top: 50%; background: linear-gradient(90deg, transparent, var(--tactical-blue), transparent); }
        #crosshair::after { content: ''; position: absolute; height: 100%; width: 1px; left: 50%; background: linear-gradient(180deg, transparent, var(--tactical-blue), transparent); }
        
        .corner { position: absolute; width: 20px; height: 20px; border: 2px solid var(--tactical-blue); opacity: 0.5; }
        .tl { top: 0; left: 0; border-right: 0; border-bottom: 0; }
        .tr { top: 0; right: 0; border-left: 0; border-bottom: 0; }
        .bl { bottom: 0; left: 0; border-right: 0; border-top: 0; }
        .br { bottom: 0; right: 0; border-left: 0; border-top: 0; }

        /* HUD OVERLAY */
        #hud {
            position: fixed; inset: 0; z-index: 20; pointer-events: none;
            border: 20px solid transparent;
            border-image: radial-gradient(circle, transparent 70%, rgba(0, 212, 255, 0.05) 100%) 30;
            transition: opacity 1s ease;
        }

        .scan-line {
            position: absolute; width: 100%; height: 4px;
            background: linear-gradient(to bottom, transparent, var(--tactical-blue), transparent);
            opacity: 0.2; top: 0; animation: scanMove 3s linear infinite;
        }
        @keyframes scanMove { 0% { top: -5%; } 100% { top: 105%; } }

        /* TERMINAL UPGRADE */
        .terminal {
            position: absolute; bottom: 80px; left: 30px;
            color: var(--defense-green); font-size: 10px;
            background: var(--glass); padding: 15px;
            border: 1px solid var(--border);
            border-left: 4px solid var(--tactical-blue);
            min-width: 280px; z-index: 30;
            box-shadow: 0 0 20px rgba(0,0,0,0.5);
            text-transform: uppercase; letter-spacing: 1px;
        }

        #secure-frame {
            position: absolute; top: 0; left: 0; width: 100%; height: calc(100% - 60px); 
            border: none; z-index: 120; opacity: 0; display: none;
            transform: scale(1.05); filter: blur(10px);
            transition: opacity 1.5s ease, transform 1.2s ease, filter 1.2s ease;
        }
        #secure-frame.active {
            display: block; opacity: 1; transform: scale(1); filter: blur(0);
        }

        /* FOOTER BRANDING */
        .tactical-footer {
            position: fixed; bottom: 0; width: 100%; z-index: 130;
            background: rgba(0, 5, 10, 0.95);
            border-top: 1px solid var(--tactical-blue);
            padding: 15px 0; text-align: center; color: white;
            backdrop-filter: blur(10px);
        }
        .motto {
            font-size: 10px; letter-spacing: 2px; text-transform: uppercase;
            font-weight: bold; animation: alert-glow 3s infinite;
        }
        @keyframes alert-glow {
            0%, 100% { color: var(--tactical-blue); text-shadow: 0 0 5px var(--siren-blue); }
            50% { color: #fff; text-shadow: 0 0 15px var(--tactical-blue); }
        }

        .tactical-label {
            background: rgba(0, 10, 20, 0.8) !important; border: 1px solid var(--tactical-blue) !important;
            color: var(--tactical-blue) !important; font-weight: bold !important;
            font-size: 9px !important; letter-spacing: 1px;
        }
    </style>
</head>
<body oncontextmenu="return false;">

    <div id="bg-container"></div>
    <div id="map"></div>
    
    <div id="crosshair">
        <div class="corner tl"></div>
        <div class="corner tr"></div>
        <div class="corner bl"></div>
        <div class="corner br"></div>
    </div>

    <div id="hud">
        <div class="header-branding" id="logoBox">
            <img src="pro9 logo.png" class="pnp-logo-main" alt="PNP PRO9">
            <div style="color: var(--tactical-blue); letter-spacing: 5px; font-size: 0.7rem; font-weight: bold;">POLICE REGIONAL OFFICE 9</div>
        </div>

        <div class="scan-line"></div>
        <div class="terminal" id="term">
            [SYS] KERNEL INITIALIZED...<br>
            [NET] ESTABLISHING SECURE TUNNEL...<br>
            [GEO] TRACKING REGIONAL NODES...<br>
            [CMD] <span id="sync" style="color: var(--training-gold);">RECOGNIZING AOR...</span>
        </div>
    </div>

    <iframe id="secure-frame" 
            src="https://script.google.com/macros/s/AKfycbwQe5xpaGLp_3pZMFYhGuD98lVYpH_tGNvdkg2OHJ6x9t7_4VdW9t9g3yhWxJb_hABM/exec">
    </iframe>

    <footer class="tactical-footer">
        <span class="motto">“Bagong PNP para sa Bagong Pilipinas: Serbisyong Mabilis, Tapat, at Nararamdaman”</span><br>
        <span style="font-size: 8px; opacity: 0.4; letter-spacing: 1px;">OPRMD PRO9 | SECURE COMPETENCY PORTAL</span>
    </footer>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <script>
        const sectors = [
            { n: "HQ PRO9", p: [6.92, 122.07] },
            { n: "ISABELA", p: [6.70, 121.97] },
            { n: "SULU UNIT", p: [6.00, 121.00] },
            { n: "ZAMBO SUR", p: [7.82, 123.43] },
            { n: "ZAMBO NORTE", p: [8.18, 123.00] },
            { n: "SIBUGAY", p: [7.73, 122.58] }
        ];

        const map = L.map('map', { 
            zoomControl: false, 
            attributionControl: false,
            dragging: false,
            scrollWheelZoom: false,
            doubleClickZoom: false
        }).setView(sectors[0].p, 13);

        L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}').addTo(map);

        async function initSequence() {
            const term = document.getElementById('term');
            const sync = document.getElementById('sync');

            // 1. OMNI-SCANNING PHASE
            for (let i = 0; i < 4; i++) {
                let target = sectors[i % sectors.length];
                term.innerHTML += `<br>[SCAN] SECTOR: ${target.n} ACTIVE`;
                map.flyTo(target.p, 14, { animate: true, duration: 1.5 });
                await new Promise(r => setTimeout(r, 1800));
            }

            // 2. WIDE-ANGLE LOCK
            term.innerHTML += `<br>[NAV] LOCKING REGIONAL TOPOLOGY...`;
            map.flyTo([7.5, 122.3], 8.5, { duration: 2.5 });

            setTimeout(() => {
                sectors.forEach(s => {
                    L.circleMarker(s.p, {
                        radius: 5, color: '#fff', fillColor: '#00d4ff', fillOpacity: 0.8, weight: 1
                    }).addTo(map).bindTooltip(s.n, {permanent: true, direction: 'right', className: 'tactical-label'});
                });
                
                sync.innerText = "UPLINK ESTABLISHED - ENCRYPTED";
                sync.style.color = "var(--defense-green)";
                document.getElementById('crosshair').style.transform = "translate(-50%, -50%) scale(1.5)";
                document.getElementById('crosshair').style.opacity = "0";
            }, 2000);

            // 3. SECURE DE-CLOAK TRANSITION
            setTimeout(() => {
                const frame = document.getElementById('secure-frame');
                const hud = document.getElementById('hud');
                const logo = document.getElementById('logoBox');
                
                frame.classList.add('active');
                hud.style.opacity = "0";
                logo.style.opacity = "0";
                map.style.filter = "brightness(0.1) blur(5px)";
            }, 4500);
        }

        // Trigger on frame load for smoother timing
        document.getElementById('secure-frame').onload = () => {
            initSequence();
        };

        // Security
        document.onkeydown = (e) => { 
            if(e.keyCode == 123 || (e.ctrlKey && (e.shiftKey && (e.keyCode == 73 || e.keyCode == 74) || e.keyCode == 85))) return false; 
        };
    </script>
</body>
</html>
